        {
          "name": "Get Manifest",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/manifest/:type/:name",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manifest", ":type", ":name"],
              "variable": [
                {
                  "key": "type",
                  "value": "agents",
                  "description": "Artifact type: agents, tools, pipelines, or skills"
                },
                {
                  "key": "name",
                  "value": "hello-world",
                  "description": "Name of the artifact"
                }
              ]
            },
            "description": "Retrieve the raw YAML manifest for a specific artifact."
          },
          "response": []
        },
        {
          "name": "Validate Manifest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "text/plain" }
            ],
            "body": {
              "mode": "raw",
              "raw": "name: my-tool\ndescription: A sample tool\ndriver:\n  type: http\n  method: GET\n  url: https://example.com/api"
            },
            "url": {
              "raw": "{{baseUrl}}/api/validate/:type",
              "host": ["{{baseUrl}}"],
              "path": ["api", "validate", ":type"],
              "variable": [
                {
                  "key": "type",
                  "value": "tools",
                  "description": "Artifact type to validate: agents, tools, pipelines, or skills"
                }
              ]
            },
            "description": "Validate an artifact manifest YAML against its schema."
          },
          "response": [
            {
              "name": "200 OK - Valid",
              "status": "OK",
              "code": 200,
              "body": "{\"valid\": true, \"errors\": []}",
              "header": [{ "key": "Content-Type", "value": "application/json" }]
            }
          ]
        },
        {
          "name": "Save Manifest",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "text/plain" }
            ],
            "body": {
              "mode": "raw",
              "raw": "name: my-tool\ndescription: A sample tool\ndriver:\n  type: http\n  method: GET\n  url: https://example.com/api"
            },
            "url": {
              "raw": "{{baseUrl}}/api/manifest/:type/:name",
              "host": ["{{baseUrl}}"],
              "path": ["api", "manifest", ":type", ":name"],
              "variable": [
                {
                  "key": "type",
                  "value": "tools",
                  "description": "Artifact type: agents, tools, pipelines, or skills"
                },
                {
                  "key": "name",
                  "value": "my-tool",
                  "description": "Name of the artifact to save"
                }
              ]
            },
            "description": "Save or update an artifact manifest."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\"saved\": true, \"errors\": []}",
              "header": [{ "key": "Content-Type", "value": "application/json" }]
            }
          ]
        }
      ]
    },
