            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request\": \"Analyze this data\",\n  \"context\": null,\n  \"agentName\": null,\n  \"conversationId\": null,\n  \"model\": null\n}",
              "options": { "raw": { "language": "json" } }
