{
  "info": {
    "name": "Hubbers API",
    "description": "Complete API collection for the Hubbers framework — a Git-native Java runtime for AI agents, tools, pipelines, and skills.\n\nBase URL: http://localhost:7070\n\nAuthentication: Bearer token via Authorization header (skip for /api/health).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{apiKey}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:7070",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "",
      "type": "string"
    },
    {
      "key": "executionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Configuration",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Returns server health status. No authentication required."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\"status\": \"ok\"}",
              "header": [{ "key": "Content-Type", "value": "application/json" }]
            }
          ]
        },
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/settings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings"]
            },
            "description": "Retrieve the current application configuration (AppConfig)."
          },
          "response": []
        },
        {
          "name": "Save Settings",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ollama\": {\n    \"baseUrl\": \"http://localhost:11434\",\n    \"model\": \"llama3\"\n  },\n  \"security\": {\n    \"apiKey\": \"\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/settings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "settings"]
            },
            "description": "Save/update the application configuration."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\"success\": true, \"message\": \"Settings saved successfully\"}",
              "header": [{ "key": "Content-Type", "value": "application/json" }]
            }
          ]
        },
        {
          "name": "List Models",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/models",
              "host": ["{{baseUrl}}"],
              "path": ["api", "models"]
            },
            "description": "List available LLM models from all configured providers (Ollama, OpenAI, Anthropic, etc.)."
          },
          "response": []
        }
      ]
    },
