{
  "name": "hubbers-vscode",
  "displayName": "Hubbers",
  "description": "Git-native AI agent framework integration for VS Code — edit, validate, and run agents, tools, pipelines, and skills.",
  "version": "0.1.0",
  "publisher": "hubbers",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "ai",
    "agent",
    "llm",
    "pipeline",
    "mcp"
  ],
  "activationEvents": [
    "workspaceContains:**/agent.yaml",
    "workspaceContains:**/tool.yaml",
    "workspaceContains:**/pipeline.yaml",
    "workspaceContains:**/SKILL.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hubbers-explorer",
          "title": "Hubbers",
          "icon": "resources/icons/hubbers.svg"
        }
      ]
    },
    "views": {
      "hubbers-explorer": [
        {
          "id": "hubbersArtifacts",
          "name": "Artifacts",
          "icon": "resources/icons/hubbers.svg",
          "contextualTitle": "Hubbers Artifacts"
        }
      ]
    },
    "commands": [
      {
        "command": "hubbers.refreshArtifacts",
        "title": "Refresh Artifacts",
        "icon": "$(refresh)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.runArtifact",
        "title": "Run Artifact",
        "icon": "$(play)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.runCurrentArtifact",
        "title": "Run Current Artifact",
        "icon": "$(play)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.openArtifact",
        "title": "Open File",
        "icon": "$(go-to-file)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.configureMcp",
        "title": "Configure MCP Server",
        "icon": "$(plug)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.importArtifacts",
        "title": "Import Artifacts from Folder...",
        "icon": "$(cloud-download)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.newArtifact",
        "title": "New Artifact...",
        "icon": "$(add)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.newAgent",
        "title": "New Agent...",
        "icon": "$(add)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.newTool",
        "title": "New Tool...",
        "icon": "$(add)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.newPipeline",
        "title": "New Pipeline...",
        "icon": "$(add)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.newSkill",
        "title": "New Skill...",
        "icon": "$(add)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.newInputFile",
        "title": "New Input File...",
        "icon": "$(add)",
        "category": "Hubbers"
      },
      {
        "command": "hubbers.deleteInputFile",
        "title": "Delete Input File",
        "icon": "$(trash)",
        "category": "Hubbers"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hubbers.refreshArtifacts",
          "when": "view == hubbersArtifacts",
          "group": "navigation@1"
        },
        {
          "command": "hubbers.newArtifact",
          "when": "view == hubbersArtifacts",
          "group": "navigation@2"
        },
        {
          "command": "hubbers.importArtifacts",
          "when": "view == hubbersArtifacts",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "hubbers.runArtifact",
          "when": "view == hubbersArtifacts && viewItem == artifact",
          "group": "inline@1"
        },
        {
          "command": "hubbers.openArtifact",
          "when": "view == hubbersArtifacts && viewItem == artifact",
          "group": "inline@2"
        },
        {
          "command": "hubbers.newInputFile",
          "when": "view == hubbersArtifacts && viewItem == artifact",
          "group": "inline@3"
        },
        {
          "command": "hubbers.runArtifact",
          "when": "view == hubbersArtifacts && viewItem == artifact",
          "group": "hubbers@1"
        },
        {
          "command": "hubbers.newInputFile",
          "when": "view == hubbersArtifacts && viewItem == artifact",
          "group": "hubbers@2"
        },
        {
          "command": "hubbers.newAgent",
          "when": "view == hubbersArtifacts && viewItem == category-agent",
          "group": "inline@1"
        },
        {
          "command": "hubbers.newTool",
          "when": "view == hubbersArtifacts && viewItem == category-tool",
          "group": "inline@1"
        },
        {
          "command": "hubbers.newPipeline",
          "when": "view == hubbersArtifacts && viewItem == category-pipeline",
          "group": "inline@1"
        },
        {
          "command": "hubbers.newSkill",
          "when": "view == hubbersArtifacts && viewItem == category-skill",
          "group": "inline@1"
        },
        {
          "command": "hubbers.newAgent",
          "when": "view == hubbersArtifacts && viewItem == category-agent",
          "group": "hubbers@1"
        },
        {
          "command": "hubbers.newTool",
          "when": "view == hubbersArtifacts && viewItem == category-tool",
          "group": "hubbers@1"
        },
        {
          "command": "hubbers.newPipeline",
          "when": "view == hubbersArtifacts && viewItem == category-pipeline",
          "group": "hubbers@1"
        },
        {
          "command": "hubbers.newSkill",
          "when": "view == hubbersArtifacts && viewItem == category-skill",
          "group": "hubbers@1"
        },
        {
          "command": "hubbers.runArtifact",
          "when": "view == hubbersArtifacts && viewItem == inputFile",
          "group": "inline@1"
        },
        {
          "command": "hubbers.deleteInputFile",
          "when": "view == hubbersArtifacts && viewItem == inputFile",
          "group": "inline@2"
        },
        {
          "command": "hubbers.runArtifact",
          "when": "view == hubbersArtifacts && viewItem == inputFile",
          "group": "hubbers@1"
        },
        {
          "command": "hubbers.deleteInputFile",
          "when": "view == hubbersArtifacts && viewItem == inputFile",
          "group": "hubbers@2"
        }
      ],
      "commandPalette": [
        {
          "command": "hubbers.runArtifact",
          "when": "false"
        },
        {
          "command": "hubbers.openArtifact",
          "when": "false"
        },
        {
          "command": "hubbers.newInputFile",
          "when": "false"
        },
        {
          "command": "hubbers.deleteInputFile",
          "when": "false"
        },
        {
          "command": "hubbers.newAgent",
          "when": "false"
        },
        {
          "command": "hubbers.newTool",
          "when": "false"
        },
        {
          "command": "hubbers.newPipeline",
          "when": "false"
        },
        {
          "command": "hubbers.newSkill",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "hubbers.importArtifacts",
          "when": "explorerResourceIsFolder",
          "group": "hubbers@1"
        }
      ]
    },
    "yamlValidation": [
      {
        "fileMatch": "**/agent.yaml",
        "url": "./schemas/agent.schema.json"
      },
      {
        "fileMatch": "**/tool.yaml",
        "url": "./schemas/tool.schema.json"
      },
      {
        "fileMatch": "**/pipeline.yaml",
        "url": "./schemas/pipeline.schema.json"
      }
    ],
    "configuration": {
      "title": "Hubbers",
      "properties": {
        "hubbers.jarPath": {
          "type": "string",
          "default": "",
          "description": "Path to hubbers.jar or the 'hubbers' CLI executable. Leave empty to auto-detect from PATH."
        },
        "hubbers.repoPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Hubbers artifact repository root (the folder containing agents/, tools/, pipelines/, skills/). Leave empty to use the workspace root."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "webpack --config webpack.config.js --mode production",
    "compile": "webpack --config webpack.config.js",
    "watch": "webpack --watch --config webpack.config.js",
    "vsce-package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
